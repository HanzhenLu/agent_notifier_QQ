# QQ Bot credentials
QQ_APP_ID=
QQ_APP_SECRET=

# QQ sandbox API base
QQ_API_BASE=https://sandbox.api.sgroup.qq.com

# Shared invite secret used by /bind command in QQ DM.
# Anyone who knows this secret can register their QQ as a notify target.
# Treat it like an invite code — do NOT make it public.
BIND_SECRET=

# Prefix prepended to generated agent_token (for log/secret-scanner readability).
TOKEN_PREFIX=ant_

# SQLite db path
# 本地直接运行时使用相对路径，避免 /data 目录权限问题；
# Docker 环境下由 docker-compose 覆盖为 /data/agent_notifier.db。
DB_PATH=./data/agent_notifier.db

# API server
HOST=0.0.0.0
PORT=8000

# Message behavior
MAX_MESSAGE_LENGTH=1800
