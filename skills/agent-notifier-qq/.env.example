# 复制本文件为 .env，然后填入下方两个变量。.env 已被 .gitignore 忽略。
#
#   cp skills/agent-notifier-qq/.env.example skills/agent-notifier-qq/.env
#

# 1. 你部署的 agent-notifier-qq 服务的 agent-done 接口完整地址。
#    必须带 http(s):// 协议头和 /v1/notify/agent-done 路径。
#    例：http://124.221.193.250:8000/v1/notify/agent-done
#    例：https://notify.example.com/v1/notify/agent-done
AGENT_NOTIFY_URL=

# 2. 在 QQ 里给机器人发 "/bind <别名>" 后机器人回复的 token，形如 ant_xxxxxxxxxxxx
#    每个 QQ 用户拿到的 token 不同，请用你自己的。
AGENT_TOKEN=

# 3. （可选）agent 显示名，会出现在通知里。不填则默认 "agent"。
# AGENT_NAME=claude
